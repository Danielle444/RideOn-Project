{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "--prefix",
        "RideOnClient/rideon-client/web",
        "run",
        "dev"
      ],
      "port": 5173
    },
    {
      "name": "server",
      "runtimeExecutable": "dotnet",
      "runtimeArgs": [
        "run",
        "--project",
        "RideOnServer"
      ],
      "port": 5268
    },
    {
      "name": "mobile",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "--prefix",
        "RideOnClient/rideon-client/mobile",
        "start"
      ],
      "port": 8081
    }
  ]
}
